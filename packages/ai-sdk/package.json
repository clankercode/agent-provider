{
  "name": "@agent-provider/ai-sdk",
  "version": "0.1.0",
  "description": "AI SDK LanguageModel fulfilled through the Agent Provider extension.",
  "license": "CC0-1.0 OR Unlicense",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap --clean && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agent-provider/protocol": "0.1.0",
    "@ai-sdk/provider": "^4.0.3"
  },
  "peerDependencies": {
    "ai": ">=7.0.34 <8"
  },
  "devDependencies": {
    "ai": "^7.0.34",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
