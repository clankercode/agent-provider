{
  "name": "@agent-provider/react",
  "version": "0.1.0",
  "description": "React bindings and reference chat surface for Agent Provider.",
  "license": "CC0-1.0 OR Unlicense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clankercode/agent-provider.git",
    "directory": "packages/react"
  },
  "keywords": [
    "browser",
    "llm",
    "react",
    "agent-provider"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "LICENSE-CC0",
    "UNLICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap --clean && cp src/styles.css dist/styles.css && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agent-provider/runtime": "0.1.0"
  },
  "peerDependencies": {
    "react": ">=18.3",
    "react-dom": ">=18.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
